{% set domain = 'front_office' %}
{% if is_granted('ROLE_ADMIN') %}
    {% set domain = 'back_office' %}
{% elseif is_granted('ROLE_MEMBER') %}
    {% set domain = 'member' %}
{% elseif is_granted('ROLE_PARTNER') %}
    {% set domain = 'partner' %}
{% endif %}
{% extends domain ~ '/_layout.html.twig' %}

{% block title %}Mon Compte{% endblock %}
{% block meta_description %}{% endblock %}
{% block body_class %}frontoffice form{% endblock %}

{% block main %}
    <section class="app-section pagetitle">
        <h1>
            Mon Compte
            {% if is_granted('ROLE_ADMIN') %}
                Administrateur
            {% elseif is_granted('ROLE_MEMBER') %}
                Adhérent
            {% elseif is_granted('ROLE_PARTNER') %}
                Partenaire
            {% endif %}
        </h1>
    </section>

    <section class="app-section form">
        {{ form_start(form, {'attr': {'class': 'app-form'}}) }}
        <fieldset class="form-fieldset">
            <legend class="form-legend">Vos infos perso</legend>

            <div class="form-group">
                {{ form_label(form.gender) }}
                {{ form_widget(form.gender) }}
                {{ form_errors(form.gender) }}
            </div>

            <div class="form-group">
                {{ form_label(form.firstname) }}
                {{ form_widget(form.firstname) }}
                {{ form_errors(form.firstname) }}
            </div>

            <div class="form-group">
                {{ form_label(form.lastname) }}
                {{ form_widget(form.lastname) }}
                {{ form_errors(form.lastname) }}
            </div>

            <div class="form-group">
                {{ form_label(form.pseudo) }}
                {{ form_widget(form.pseudo) }}
                {{ form_errors(form.pseudo) }}
            </div>

            {% if not is_granted('ROLE_ADMIN') %}
                <div class="form-group">
                    {{ form_label(form.logo) }}
                    {% if app.user.logo is defined and app.user.logo %}
                        <div class="app-grid two nobg">
                            <div class="grid-item nobg">
                                {{ form_widget(form.logo) }}
                                {{ form_errors(form.logo) }}
                            </div>
                            <div class="grid-item nobg">
                                {% if app.user.memberType is defined %}
                                    <div class="app-grid third-reverse nobg">
                                        <a href="{{ asset('uploads/member/' ~ app.user.logo) }}"
                                           target="_blank"
                                           class="grid-item nobg">
                                            <small>{{ app.user.logo }}</small>
                                        </a>
                                        <a href="{{ path('app_profile_logo_delete') }}"
                                           class="grid-item nobg text-danger"
                                           onclick="return window.confirm('Êtes-vous sûr de vouloir supprimer votre logo ?')">
                                            {{ ux_icon('fa6-solid:trash-can', {'class': 'icon text-danger'}) }}
                                        </a>
                                    </div>
                                {% elseif app.user.partnerType is defined %}
                                    <div class="app-grid third-reverse nobg">
                                        <a href="{{ asset('uploads/partner/' ~ app.user.logo) }}"
                                           target="_blank"
                                           class="grid-item nobg">
                                            <small>{{ app.user.logo }}</small>
                                        </a>
                                        <a href="{{ path('app_profile_logo_delete') }}"
                                           class="grid-item nobg text-danger"
                                           onclick="return window.confirm('Êtes-vous sûr de vouloir supprimer votre logo ?')">
                                            {{ ux_icon('fa6-solid:trash-can', {'class': 'icon text-danger'}) }}
                                        </a>
                                    </div>
                                {% endif %}
                            </div>
                        </div>
                    {% else %}
                        {{ form_widget(form.logo) }}
                        {{ form_errors(form.logo) }}
                    {% endif %}
                </div>
            {% endif %}
        </fieldset>

        <fieldset class="form-fieldset">
            <legend class="form-legend">Votre compte chez BSS</legend>

            {% if is_granted('ROLE_MEMBER') %}
                <div class="form-group">
                    {{ form_label(form.memberType) }}
                    {{ form_widget(form.memberType) }}
                    {{ form_errors(form.memberType) }}
                </div>
            {% elseif is_granted('ROLE_PARTNER') %}
                <div class="form-group">
                    {{ form_label(form.partnerType) }}
                    {{ form_widget(form.partnerType) }}
                    {{ form_errors(form.partnerType) }}
                </div>
            {% endif %}

            <div class="form-group">
                {{ form_label(form.email) }}
                {{ form_widget(form.email) }}
                {{ form_errors(form.email) }}
            </div>

            <div class="form-group">
                {{ form_label(form.plainPassword) }}
                {{ form_widget(form.plainPassword) }}
                {{ form_help(form.plainPassword) }}
                {{ form_errors(form.plainPassword) }}
            </div>
        </fieldset>

        {% if not is_granted('ROLE_ADMIN') %}
            <fieldset class="form-fieldset">
                <legend class="form-legend">Vos coordonnées</legend>

                <div class="form-group">
                    {{ form_label(form.address1) }}
                    {{ form_widget(form.address1) }}
                    {{ form_errors(form.address1) }}
                </div>

                <div class="form-group">
                    {{ form_label(form.address2) }}
                    {{ form_widget(form.address2) }}
                    {{ form_errors(form.address2) }}
                </div>

                <div class="form-group">
                    {{ form_label(form.address3) }}
                    {{ form_widget(form.address3) }}
                    {{ form_errors(form.address3) }}
                </div>

                <div class="form-group">
                    {{ form_label(form.zipcode) }}
                    {{ form_widget(form.zipcode) }}
                    {{ form_errors(form.zipcode) }}
                </div>

                <div class="form-group">
                    {{ form_label(form.city) }}
                    {{ form_widget(form.city) }}
                    {{ form_errors(form.city) }}
                </div>

                <div class="form-group">
                    {{ form_label(form.country) }}
                    {{ form_widget(form.country) }}
                    {{ form_errors(form.country) }}
                </div>

                <div class="form-group">
                    {{ form_label(form.phone) }}
                    {{ form_widget(form.phone) }}
                    {{ form_errors(form.phone) }}
                </div>
            </fieldset>
        {% endif %}

        <div class="form-group">
            <span>&nbsp;</span>
            <button type="submit" class="form-submit app-btn cta">Enregistrez</button>
        </div>

        {{ form_end(form) }}
    </section>
{% endblock %}
